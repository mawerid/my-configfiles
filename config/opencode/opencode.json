{
    "$schema": "https://opencode.ai/config.json",
    "enabled_providers": [
        "lmstudio",
        "github-copilot"
    ],
    "model": "lmstudio/qwen/qwen3.5-9b",
    "small_model": "lmstudio/nvidia/nemotron-3-nano-4b",
    "share": "disabled",
    "default_agent": "chat-safe",
    "instructions": [
        "~/.config/opencode/AGENTS.md"
    ],
    "provider": {
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LM Studio (local)",
            "options": {
                "baseURL": "http://127.0.0.1:1234/v1",
                "timeout": 180000,
                "chunkTimeout": 30000
            },
            "models": {
                "qwen/qwen3.5-9b": {
                    "name": "Qwen3.5 9B (local)"
                },
                "nvidia/nemotron-3-nano-4b": {
                    "name": "Nemotron 3 Nano 4B (local)"
                }
            }
        }
    },
    "permission": {
        "*": "ask",
        "external_directory": "deny",
        "task": "ask",
        "read": {
            "*": "allow",
            ".env": "deny",
            ".env.*": "deny",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.pem": "deny",
            "*.key": "deny",
            "*.p12": "deny",
            "*.crt": "deny",
            "*.der": "deny",
            "*.pfx": "deny",
            "*.sqlite": "deny",
            "*.db": "deny",
            "*.kdbx": "deny"
        },
        "edit": "ask",
        "webfetch": "ask",
        "websearch": "ask",
        "codesearch": "ask",
        "bash": {
            "*": "ask",
            "pwd": "allow",
            "ls": "allow",
            "ls *": "allow",
            "tree": "allow",
            "tree *": "allow",
            "git status": "allow",
            "git status *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "python -V": "allow",
            "python3 -V": "allow",
            "node -v": "allow",
            "npm -v": "allow",
            "uv --version": "allow",
            "cargo --version": "allow",
            "cmake --version": "allow",
            "pytest *": "ask",
            "uv run pytest *": "ask",
            "npm test *": "ask",
            "cargo test *": "ask",
            "cmake *": "ask",
            "make *": "ask",
            "git add *": "ask",
            "git commit *": "ask",
            "git push *": "deny",
            "git tag *": "ask",
            "rm *": "deny",
            "mv *": "ask",
            "cp *": "ask",
            "chmod *": "ask",
            "curl *": "ask",
            "wget *": "ask",
            "ssh *": "deny",
            "scp *": "deny",
            "rsync *": "ask",
            "docker *": "ask",
            "podman *": "ask"
        }
    }
}